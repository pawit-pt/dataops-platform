          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "title": "DQ Check Avg Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "airflow_task_duration_seconds_sum{dag_id=~\"gold_aggregation|test_dq_and_batch\"} / airflow_task_duration_seconds_count{dag_id=~\"gold_aggregation|test_dq_and_batch\"}",
          "legendFormat": "{{ dag_id }} / {{ task_id }}",
          "refId": "A"
        }
      ]
    },
